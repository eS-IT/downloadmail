        "phpunit/phpunit": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "Esit\\Smartgallery\\": ""
        }
    },
    "extra": {
        "contao-manager-plugin": "Esit\\Smartgallery\\Classes\\Contao\\Manager\\Plugin"
    }
